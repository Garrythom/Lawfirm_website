# Local mock server (server/), only needed if you run it directly for
# content/search endpoints. Not used in production on Vercel.
PORT=4000
VITE_API_BASE_URL=http://localhost:4000

# --- Contact form email (Resend) -------------------------------------------
# Copy this file to .env for local `vercel dev` testing. In production, set
# these in the Vercel dashboard instead: Project -> Settings -> Environment
# Variables. Never commit a real .env file — it's already git-ignored.

# Resend API key (Dashboard -> API Keys -> Create API Key)
RESEND_API_KEY=

# Where contact form / "Submit Case" submissions should be delivered.
# While using Resend's shared onboarding@resend.dev sender (no verified
# domain yet), this MUST be the same email address your Resend account
# is registered with — Resend only allows that sender to deliver to its
# own account owner until a custom domain is verified.
CONTACT_TO_EMAIL=

# Optional: only set this once you've verified your own domain in Resend.
# Until then, leave unset — the function defaults to Resend's shared
# onboarding@resend.dev sender, which requires no domain setup.
# RESEND_FROM_EMAIL=Pacific Gate Law Firm <noreply@yourdomain.com>
